<Window x:Class="Pc_parts_lister.DetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pc_parts_lister"
        mc:Ignorable="d"
        Title="Detail Window" Height="500" Width="600" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*" />
            <RowDefinition Height="0.9*"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="Gray" Grid.ColumnSpan="2" Grid.Row="0" BorderThickness="0,0,0,2">
            <StackPanel>
                <Button Click="Back_Click" Height="30" Width="30" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,10,10,0">
                    <Button.Background>
                        <ImageBrush Stretch="UniformToFill" ImageSource="/back_button.png"/>
                    </Button.Background>
                </Button>
                <TextBlock Text="{Binding Name}" FontSize="36" FontWeight="Bold"/>
            </StackPanel>
        </Border>
        <StackPanel Grid.Column="0" Grid.Row="1">
            <Image Source="{Binding FullImagePath}" Stretch="Uniform" Margin="10"/>
        </StackPanel>

        <StackPanel Margin="10" Grid.Column="1" Grid.Row="1">

            <TextBlock Text="{Binding Type, StringFormat=Typ: {0}}" x:Name="TypeBox" FontSize="20" FontWeight="Bold"/>

            <TextBlock Text="{Binding SubType, StringFormat=Subtyp: {0}}" x:Name="TypeBox2" FontSize="20" FontWeight="Bold"/>

            <TextBlock Text="{Binding Series, StringFormat=Série: {0}}" x:Name="SerBox" FontSize="20" FontWeight="Bold"/>

            <TextBlock Text="{Binding SubSeries, StringFormat=SubSérie: {0}}" x:Name="SubSerBox" FontSize="20" FontWeight="Bold"/>

            <TextBlock Text="{Binding Model, StringFormat=Model: {0}}" x:Name="ModelBox" FontSize="20" FontWeight="Bold"/>

            <TextBlock Text="{Binding Capacity, StringFormat=Paměť: {0} GB}" x:Name="CapacityBox" FontSize="20" FontWeight="Bold"/>

            <TextBlock Text="{Binding Power, StringFormat=Výkon: {0}}" x:Name="PowerBox" FontSize="20" FontWeight="Bold"/>

            <TextBlock Text="{Binding Manufacturer, StringFormat=Výrobce: {0}}" x:Name="ManufacturerBox" FontSize="20" FontWeight="Bold"/>

            <TextBlock Text="{Binding Quantity, StringFormat=Množství: {0}}" x:Name="QtBox" FontSize="20" FontWeight="Bold"/>

            <TextBlock Text="{Binding Status, StringFormat=Stav: {0}}" x:Name="StatusBox" FontSize="20" FontWeight="Bold"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="5">
            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Width="auto" Height="auto"/>
        </StackPanel>
    </Grid>
</Window>
