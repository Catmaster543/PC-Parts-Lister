<Window x:Class="Pc_parts_lister.Edit_window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pc_parts_lister"
        mc:Ignorable="d"
        Title="Edit Window" Height="600" Width="800">
    
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*" />
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.7*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="Gray" Grid.ColumnSpan="2" Grid.Row="0" BorderThickness="0,0,0,2">
            <StackPanel>
                <Button Click="Back_Click" Height="30" Width="30" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,10,10,0">
                    <Button.Background>
                        <ImageBrush Stretch="UniformToFill" ImageSource="/back_button.png"/>
                    </Button.Background>
                </Button>
                <TextBox Text="{Binding Name}" FontSize="36" FontWeight="Bold" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <StackPanel Margin="10" Grid.Column="1" Grid.Row="1">

            <Grid Margin="10">
                <StackPanel x:Name="Type_Panel" Orientation="Horizontal">
                    <TextBlock Text="Typ" x:Name="TypeText" HorizontalAlignment="Left" FontWeight="Bold" FontSize="20"/>
                    <ComboBox Name="Type_Box" IsEditable="False" Text="Vyber" Margin="10,0,0,0" FontSize="20" BorderThickness="0"/>
                </StackPanel>
            </Grid>

            <Grid Margin="10" x:Name="Type_N_Subtype_Grid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Name="SubType_Panel" Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="Subtyp" x:Name="TypeText2" HorizontalAlignment="Left" FontWeight="Bold" FontSize="20"/>
                    <TextBox Text="{Binding SubType}" x:Name="TypeBox2" Margin="10,0,0,0" FontSize="20" BorderThickness="0"/>
                </StackPanel>
                
                <StackPanel Name="Series_Panel" Orientation="Horizontal" Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock Text="Série" x:Name="SerText" HorizontalAlignment="Left" FontWeight="Bold" FontSize="20"/>
                    <TextBox Text="{Binding Series}" x:Name="SerBox" Margin="10,0,0,0" FontSize="20" BorderThickness="0"/>
                </StackPanel>
                
                <StackPanel Name="SubSeries_Panel" Orientation="Horizontal" Grid.Column="1" Visibility="Collapsed" Margin="20,0,0,0">
                    <TextBlock Text="SubSérie" x:Name="SubSerText" HorizontalAlignment="Left" FontWeight="Bold" FontSize="20"/>
                    <TextBox Text="{Binding SubSeries}" x:Name="SubSerBox" Margin="10,0,0,0" FontSize="20" BorderThickness="0"/>
                </StackPanel>
            </Grid>

            <StackPanel Margin="10" Name="Model_Panel" Orientation="Horizontal">
                <TextBlock Text="Model" x:Name="ModelText" HorizontalAlignment="Left" FontWeight="Bold" FontSize="20"/>
                <TextBox Text="{Binding Model}" x:Name="ModelBox" Margin="10,0,0,0" FontSize="20" BorderThickness="0"/>
            </StackPanel>

            <Grid Margin="10" Name="Etc_Grid" Visibility="Collapsed">
                <StackPanel Name="Capacity_Panel" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="Paměť" x:Name="CapacityText" HorizontalAlignment="Left" FontWeight="Bold" FontSize="20"/>
                    <TextBox Text="{Binding Capacity}" x:Name="CapacityBox" Margin="10,0,0,0" FontSize="20" TextChanged="Capacity_TextChanged" BorderThickness="0"/>
                    <TextBlock Text="GB" HorizontalAlignment="Left" FontWeight="Bold" FontSize="20" Margin="5,0,0,0"/>
                </StackPanel>
                <StackPanel Name="Power_Panel" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="Výkon ve w" x:Name="PowerText" HorizontalAlignment="Left" FontWeight="Bold" FontSize="20"/>
                    <TextBox Text="{Binding Power}" x:Name="PowerBox" Margin="10,0,0,0" FontSize="20" TextChanged="Power_TextChanged" BorderThickness="0"/>
                    <TextBlock Text="W" HorizontalAlignment="Left" FontWeight="Bold" FontSize="20" Margin="5,0,0,0"/>
                </StackPanel>
            </Grid>

            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="Výrobce" x:Name="ManufacturerText" HorizontalAlignment="Left" FontWeight="Bold" FontSize="20"/>
                    <TextBox Text="{Binding Manufacturer}" x:Name="ManufacturerBox" Margin="10,0,0,0" FontSize="20" BorderThickness="0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock Text="Množství" x:Name="CountText" HorizontalAlignment="Left" FontWeight="Bold" FontSize="20"/>
                    <TextBox Text="{Binding Quantity}" x:Name="CountBox" Margin="10,0,0,0" FontSize="20" TextChanged="Count_TextChanged" BorderThickness="0"/>
                </StackPanel>
            </Grid>

            <StackPanel Margin="10" Orientation="Horizontal">
                <TextBlock x:Name="StatusText" Text="Stav" HorizontalAlignment="Left" FontWeight="Bold" FontSize="20"/>
                <ComboBox x:Name="StatusBox" IsEditable="False" Text="Vyber" Margin="10,0,0,0" FontSize="20" BorderThickness="0"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Margin="10" Grid.Column="0" Grid.Row="1">
            <Image Source="{Binding FullImagePath}" Stretch="Uniform" x:Name="Main_pic" MaxHeight="250"/>
            <Button Content="Vybrat obrázek" Click="SelectImage_Click" BorderThickness="0,0,0,0" FontSize="20" FontWeight="Bold"/>
        </StackPanel>
        
        <StackPanel Grid.ColumnSpan="2" Grid.Row="2">
            <Button Content="Uložit" Name="Save_Button" Margin="10" Click="Save_Click" FontWeight="Bold" FontSize="25" Background="SpringGreen"/>
        </StackPanel>

        <StackPanel x:Name="ErrorPanel" Grid.Row="3" Grid.ColumnSpan="2">
            
        </StackPanel>
    </Grid>
</Window>
