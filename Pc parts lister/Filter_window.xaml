<Window x:Class="Pc_parts_lister.Filter_window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pc_parts_lister"
        mc:Ignorable="d"
        Title="Filter components" Height="450" Width="450" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Name="Stack_Panel_L" Grid.Column="0">
            <TextBlock x:Name="TypeText" Text="Typ:"/>
            <ComboBox x:Name="TypeBox" SelectionChanged="TypeBox_SelectionChanged" Text="Vyber, nebo napiš vlastní"/>

            <TextBlock x:Name="Manufacturertext" Text="Výrobce:"/>
            <ComboBox x:Name="ManufacturerBox" SelectionChanged="ManufacturerBox_SelectionChanged" IsEditable="True" Text="Vyber, nebo napiš vlastní"/>

            <TextBlock x:Name="StatusText" Text="Stav:"/>
            <ComboBox x:Name="StatusBox" IsEditable="False" Text="Vyber"/>

            <TextBlock x:Name="CountText" Text="Množství:"/>
            <Grid x:Name="CountGrid" Height="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Click="Count_Smaller_Click" Grid.Column="0" BorderBrush="Red">
                    <Button.Background>
                        <ImageBrush ImageSource="/smaller_button.png" Stretch="UniformToFill"/>
                    </Button.Background>
                </Button>
                <Button Click="Count_Bigger_Click" Grid.Column="1" BorderBrush="#FF4EFF00">
                    <Button.Background>
                        <ImageBrush ImageSource="/bigger_button.png" Stretch="UniformToFill"/>
                    </Button.Background>
                </Button>
                <Button Click="Count_Same_Click" Grid.Column="2">
                    <Button.Background>
                        <ImageBrush Stretch="UniformToFill" ImageSource="/equals_button.png"/>
                    </Button.Background>
                </Button>
                <TextBox x:Name="CountBox" Grid.Column="3" TextChanged="Count_TextChanged" BorderBrush="#FFB3ABAB"/>
            </Grid>
        </StackPanel>
        <StackPanel Name="Stack_Panel_R" Grid.Column="2">
            <TextBlock x:Name="TypeText2" Text="Typ:"/>
            <ComboBox x:Name="TypeBox2" SelectionChanged="TypeBox2_SelectionChanged" IsEditable="False" Text="Vyber, nebo napiš vlastní"/>

            <TextBlock x:Name="SerText" Text="Série:"/>
            <ComboBox x:Name="SerBox" SelectionChanged="SerBox_SelectionChanged" IsEditable="True" Text="Vyber, nebo napiš vlastní"/>

            <TextBlock x:Name="SubSerText" Text="Řada:"/>
            <ComboBox x:Name="SubSerBox" SelectionChanged="SubSerBox_SelectionChanged" IsEditable="True" Text="Vyber, nebo napiš vlastní"/>

            <TextBlock x:Name="ModelText" Text="Model:"/>
            <TextBox x:Name="ModelBox"/>

            <TextBlock x:Name="Powertext" Text="Výkon (W):"/>
            <Grid x:Name="PowerGrid" Height="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Click="Power_Smaller_Click" Grid.Column="0" BorderBrush="Red">
                    <Button.Background>
                        <ImageBrush Stretch="UniformToFill" ImageSource="/smaller_button.png"/>
                    </Button.Background>
                </Button>
                <Button Click="Power_Bigger_Click" Grid.Column="1" BorderBrush="#FF4EFF00">
                    <Button.Background>
                        <ImageBrush Stretch="UniformToFill" ImageSource="/bigger_button.png"/>
                    </Button.Background>
                </Button>
                <Button Click="Power_Same_Click" Grid.Column="2">
                    <Button.Background>
                        <ImageBrush Stretch="UniformToFill" ImageSource="/equals_button.png"/>
                    </Button.Background>
                </Button>
                <TextBox x:Name="PowerBox" Grid.Column="3" TextChanged="Power_TextChanged" BorderBrush="#FFB3ABAB"/>
            </Grid>

            <TextBlock x:Name="CapacityText" Text="Velikost v GB:"/>
            <Grid x:Name="CapacityGrid" Height="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Click="Capacity_Smaller_Click" Grid.Column="0" BorderBrush="Red">
                    <Button.Background>
                        <ImageBrush Stretch="UniformToFill" ImageSource="/smaller_button.png"/>
                    </Button.Background>
                </Button>
                <Button Click="Capacity_Bigger_Click" Grid.Column="1" BorderBrush="#FF4EFF00">
                    <Button.Background>
                        <ImageBrush Stretch="UniformToFill" ImageSource="/bigger_button.png"/>
                    </Button.Background>
                </Button>
                <Button Click="Capacity_Same_Click" Grid.Column="2">
                    <Button.Background>
                        <ImageBrush Stretch="UniformToFill" ImageSource="/equals_button.png"/>
                    </Button.Background>
                </Button>
                <TextBox x:Name="CapacityBox" Grid.Column="3" TextChanged="Capacity_TextChanged" BorderBrush="#FFB3ABAB"/>
            </Grid>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Name="SaveNErrorPanel">
            <Button Content="Uložit filtr" Click="Save_Filter_Click" Margin="10" FontWeight="Bold" Background="SpringGreen"/>
        </StackPanel>
    </Grid>
</Window>
