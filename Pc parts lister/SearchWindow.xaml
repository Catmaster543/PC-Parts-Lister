<Window x:Class="Pc_parts_lister.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pc_parts_lister"
        mc:Ignorable="d"
        Title="Search Window" Height="450" Width="800">
    <Grid>
        <DataGrid ItemsSource="{Binding Components}"
  AutoGenerateColumns="False"
  CanUserAddRows="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Název"
                    Binding="{Binding Name}" IsReadOnly="True"/>

                <DataGridTextColumn Header="Typ"
                    Binding="{Binding Type}" IsReadOnly="True"/>

                <DataGridTextColumn Header="Výrobce"
                    Binding="{Binding Manufacturer}" IsReadOnly="True"/>

                <!-- Tlačítka -->
                <DataGridTemplateColumn Header="Akce">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                <Button Content="Detail"
                        Margin="2"
                        Click="DetailButton_Click"/>

                                <Button Content="Upravit"
                        Margin="2"
                        Background="DarkBlue"
                        Foreground="White"
                        Click="EditButton_Click"/>

                                <Button Content="Smazat"
                        Margin="2"
                        Background="DarkRed"
                        Foreground="White"
                        Click="DeleteButton_Click"/>

                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
