<Window x:Class="Pc_parts_lister.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pc_parts_lister"
        mc:Ignorable="d"
        Title="Main" Height="450" Width="800"
        Closing="Window_Closing">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Přidat součástku" HorizontalAlignment="Center" FontWeight="Bold" FontSize="36" Foreground="#FF3C3C3C" VerticalAlignment="Top" Grid.Column="0"/>
        <Button Click="Pridat" Height="300" Width="300" BorderThickness="0,0,0,0" FontWeight="Bold" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0">
            <Button.Background>
                <ImageBrush ImageSource="/add_button.png"/>
            </Button.Background>
        </Button>

        <TextBlock Text="Najít součástku" HorizontalAlignment="Center" FontWeight="Bold" FontSize="36" Foreground="#FF3C3C3C" VerticalAlignment="Top" Grid.Column="1"/>
        <Button Click="Hledat" Height="300" Width="300" BorderThickness="0,0,0,0" FontWeight="Bold" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1">
            <Button.Background>
                <ImageBrush ImageSource="/search_button.png"/>
            </Button.Background>
        </Button>
    </Grid>
</Window>
